# ──────────────────────────────────────────────────────────────
# AuthCore.API — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control.
# ──────────────────────────────────────────────────────────────

# PostgreSQL connection string
# .NET uses double-underscore (__) to map nested config sections.
# "ConnectionStrings__PostgreSQL" maps to Configuration["ConnectionStrings:PostgreSQL"]
ConnectionStrings__PostgreSQL=Host=localhost;Database=AuthCoreDB;Username=postgres;Password=YOUR_DB_PASSWORD

# JWT settings
JWT__ValidIssuer=http://localhost:5000
JWT__ValidAudience=http://localhost:4200
JWT__SecretKey=REPLACE_WITH_A_LONG_RANDOM_SECRET_MIN_32_CHARS!@#$%

# Email configrations
Smtp__Host=smtp.gmail.com
Smtp__Port=587
Smtp__Username=your@gmail.com
Smtp__Password=your_gmail_app_password
Smtp__FromName=AuthCore